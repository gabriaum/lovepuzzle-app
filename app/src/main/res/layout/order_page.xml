<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/order_page"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background">

    <!-- Container dos confetes (será animado via código) -->
    <FrameLayout
        android:id="@+id/confettiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Container principal do conteúdo -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.4">

        <!-- Coração grande -->
        <ImageView
            android:id="@+id/bigHeart"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_heart"
            app:tint="#FFB6C1"
            android:layout_marginBottom="32dp"
            android:alpha="0"
            android:scaleX="0"
            android:scaleY="0"/>

        <!-- Texto principal que aparece letra por letra -->
        <TextView
            android:id="@+id/tvMainMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:lineSpacingMultiplier="1.3"
            android:layout_marginBottom="24dp"
            android:alpha="0"/>

        <!-- Texto secundário -->
        <TextView
            android:id="@+id/tvSecondaryMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFB6C1"
            android:textSize="18sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="40dp"
            android:alpha="0"/>

        <!-- Anel animado -->
        <ImageView
            android:id="@+id/ringIcon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_ring"
            app:tint="#FFD700"
            android:layout_marginBottom="32dp"
            android:alpha="0"
            android:rotation="0"/>

        <!-- Mensagem final -->
        <TextView
            android:id="@+id/tvFinalMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:alpha="0"/>

    </LinearLayout>

    <!-- Partículas de coração flutuantes -->
    <ImageView
        android:id="@+id/floatingHeart1"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_heart"
        app:tint="#FF69B4"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.2"/>

    <ImageView
        android:id="@+id/floatingHeart2"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_heart"
        app:tint="#FFB6C1"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.8"/>

    <ImageView
        android:id="@+id/floatingHeart3"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_heart"
        app:tint="#FF1493"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.1"/>

    <ImageView
        android:id="@+id/floatingHeart4"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/ic_heart"
        app:tint="#DC143C"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.9"/>

    <ImageView
        android:id="@+id/floatingHeart5"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:src="@drawable/ic_heart"
        app:tint="#FF69B4"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"/>

    <!-- Estrelas decorativas -->
    <TextView
        android:id="@+id/star1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨"
        android:textSize="24sp"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.15"
        app:layout_constraintVertical_bias="0.3"/>

    <TextView
        android:id="@+id/star2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨"
        android:textSize="18sp"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.85"
        app:layout_constraintVertical_bias="0.25"/>

    <TextView
        android:id="@+id/star3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨"
        android:textSize="20sp"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.1"
        app:layout_constraintVertical_bias="0.7"/>

    <TextView
        android:id="@+id/star4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✨"
        android:textSize="22sp"
        android:alpha="0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_bias="0.9"
        app:layout_constraintVertical_bias="0.65"/>

</androidx.constraintlayout.widget.ConstraintLayout>